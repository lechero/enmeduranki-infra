# Container image
URBAN_LOUNGE_IMAGE=fuentastic/urban-lounge-web:latest

# Runtime application configuration
DATABASE_URL=postgresql://user:password@host:5432/dbname
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret
BETTER_AUTH_URL=https://urban-lounge.fuentastic.com
OIDC_ISSUER=https://mock.fuentastic.com
OIDC_CLIENT_ID=urban-lounge-web
OIDC_CLIENT_SECRET=urban-lounge-secret

# Optional
OIDC_SCOPE=openid,profile,email
