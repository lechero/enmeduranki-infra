# App image
FUSED_IMAGE=fuentastic/fused-web:latest

# PostgreSQL
POSTGRES_USER=fused
POSTGRES_PASSWORD=
POSTGRES_DB=fused

# Database
DATABASE_URL=postgres://fused:@fused-postgres:5432/fused

# Valkey (Redis-compatible cache)
VALKEY_URL=redis://fused-valkey:6379

# SearXNG
SEARXNG_BASE_URL=http://fused-searxng:8080
SEARXNG_SEARCH_PATH=/search
SEARXNG_DEFAULT_LANGUAGE=nl-NL
SEARXNG_DEFAULT_FORMAT=json

# OpenAI
OPENAI_API_KEY=

# Profile Research
PROFILE_RESEARCH_MODEL=gpt-4.1-mini
PROFILE_RESEARCH_TIMEOUT_MS=20000
PROFILE_RESEARCH_MAX_RESULTS=8

# GEO Scan
GEO_SCAN_MODEL=gpt-5.4-mini

# App
NEXT_PUBLIC_APP_URL=https://fused.fuentastic.com
